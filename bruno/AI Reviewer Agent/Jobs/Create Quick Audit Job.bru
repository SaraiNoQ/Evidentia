meta {
  name: Create Quick Audit Job
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/jobs
  body: multipartForm
  auth: none
}

headers {
  x-request-id: req_bruno_create_quick
}

body:multipart-form {
  file: @file({{sample_pdf_path}})
  config_json: {"review_mode":"quick_audit"}
}

script:post-response {
  if (res.body && res.body.data && res.body.data.job_id) {
    bru.setEnvVar("job_id", res.body.data.job_id);
  }
}

example {
  name: cpfl_example
  
  request: {
    url: {{base_url}}/api/jobs
    method: POST
    mode: multipartForm
    headers: {
      x-request-id: req_bruno_create_quick
    }
  
